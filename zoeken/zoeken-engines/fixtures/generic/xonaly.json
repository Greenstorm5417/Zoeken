st outrun legendary U.S Marshal...</p>\r\n            </li></ul></div>\r\n\r\n\r\n  \r\n  \r\n\r\n\r\n  \r\n\r\n\r\n<!-- WEATHER (English; auto Rain/Snow label; no cookies) -->\r\n<section id=\"wx\" aria-label=\"Weather\" data-nosnippet>\r\n\r\n\r\n\r\n\r\n  <div id=\"weather\" style=\"text-align:center;font:16px system-ui;color:#dbe5f5\">\r\n   \r\n  </div>\r\n\r\n  <script>\r\n  (function(){\r\n    const KEY = 'xonaly.weather.v1';\r\n    const el  = document.getElementById('weather');\r\n    const TZ  = 'America/Toronto';\r\n    const LOCALE = 'en-CA';\r\n\r\n    const I18N = {\r\n      current: 'Current weather',\r\n      change : 'Change location',\r\n      max    : 'Max',\r\n      min    : 'Min',\r\n      rain   : 'Rain',\r\n      snow   : 'Snow',\r\n      precip : 'Precipitation',\r\n      error  : 'Weather unavailable.'\r\n    };\r\n\r\n    const h = (s)=> String(s||'').replace(/[&<>\"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]));\r\n    const fmtDay = (iso)=>{\r\n      try{\r\n        const d = new Date(iso+'T00:00:00');\r\n        return d.toLocaleDateString(LOCALE, { weekday:'long', day:'2-digit', month:'long' });\r\n      }catch{ return iso; }\r\n    };\r\n\r\n    // --- Persist ?place / ?units once ---\r\n    (function(){\r\n      try{\r\n        const url=new URL(location.href);\r\n        const p=url.searchParams.get('place'),u=url.searchParams.get('units');\r\n        if(p||u){\r\n          let s=null;try{s=JSON.parse(localStorage.getItem(KEY)||'null');}catch{}\r\n          const base=s&&typeof s==='object'?s:{};\r\n          if(p) base.place=decodeURIComponent(p);\r\n          if(['imperial','metric'].includes(u)) base.units=u;\r\n          localStorage.setItem(KEY,JSON.stringify(base));\r\n          const keep=new URLSearchParams(location.search);keep.delete('place');keep.delete('units');\r\n          const clean=location.pathname+(keep.toString()?'?'+keep.toString():'');\r\n          history.replaceState({},'',clean);\r\n        }\r\n      }catch(e){}\r\n    })();\r\n\r\n    async function geocode(name){\r\n      const r=await fetch('https://geocoding-api.open-meteo.com/v1/search?name='+encodeURIComponent(name)+'&count=1&language=en&format=json');\r\n      if(!r.ok) return null;\r\n      const j=await r.json(); return j?.results?.[0]||null;\r\n    }\r\n\r\n    async function loadWeather(){\r\n      let s=null;try{s=JSON.parse(localStorage.getItem(KEY)||'null');}catch{}\r\n      let place=s?.place||'', units=s?.units==='imperial'?'imperial':'metric';\r\n      let lat=typeof s?.lat==='number'?s.lat:null, lon=typeof s?.lon==='number'?s.lon:null;\r\n      if(!place&&(lat==null||lon==null)){place=I18N.current;lat=43.6532;lon=-79.3832;}\r\n      if((lat==null||lon==null)&&place){\r\n        try{const hit=await geocode(place);if(hit){lat=hit.latitude;lon=hit.longitude;localStorage.setItem(KEY,JSON.stringify({place,units,lat,lon}));}}catch{}\r\n      }\r\n      if(lat==null||lon==null){lat=43.6532;lon=-79.3832;}\r\n\r\n      const temp_unit=(units==='imperial')?'fahrenheit':'celsius';\r\n      const deg=(units==='imperial')?'°F':'°C';\r\n      const precip_unit=(units==='imperial')?'inch':'mm';\r\n      const precip_label=(units==='imperial')?'in':'mm';\r\n\r\n      const dailyFields='temperature_2m_max,temperature_2m_min,precipitation_sum,precipitation_probability_max,snowfall_sum,rain_sum';\r\n      const api=`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true&daily=${dailyFields}&temperature_unit=${temp_unit}&precipitation_unit=${precip_unit}&timezone=${TZ}&forecast_days=4`;\r\n\r\n      try{\r\n        const r=await fetch(api); if(!r.ok) throw 0;\r\n        const data=await r.json(); if(!data?.current_weather) throw 0;\r\n\r\n        const temp=Math.round(data.current_weather.temperature);\r\n        const label=place||I18N.current;\r\n        const isNum=v=>typeof v==='number'&&!Number.isNaN(v);\r\n\r\n        // Today's precip type detection\r\n        const rain=data.daily?.rain_sum?.[0]||0;\r\n        const snow=data.daily?.snowfall_sum?.[0]||0;\r\n        const pSum0=data.daily?.precipitation_sum?.[0];\r\n        const pProb0=data.daily?.precipitation_probability_max?.[0];\r\n        const pVal0=isNum(pSum0)?(units==='imperial'?Math.round(pSum0*100)/100:Math.round(pSum0*10)/10):null;\r\n        const typeLabel=(snow>rain)?I18N.snow:(rain>snow)?I18N.rain:I18N.precip;\r\n        let todayLine='—';\r\n        if(pVal0!==null) todayLine=`${pVal0} ${precip_label}`;\r\n        if(isNum(pProb0)) todayLine+=(todayLine==='—'?`${pProb0}%`:` • ${pProb0}%`);\r\n\r\n        // Days\r\n        let daysHtml='';\r\n        for(let i=0;i<4;i++){\r\n          const iso=data.daily.time?.[i]; if(!iso) continue;\r\n          const max=Math.round(data.daily.temperature_2m_max[i]);\r\n          const min=Math.round(data.daily.temperature_2m_min[i]);\r\n          const rs=data.daily.rain_sum?.[i]||0, ss=data.daily.snowfall_sum?.[i]||0;\r\n          const tLabel=(ss>rs)?I18N.snow:(rs>ss)?I18N.rain:I18N.precip;\r\n          const ps=data.daily.precipitation_sum?.[i], pp=data.daily.precipitation_probability_max?.[i];\r\n          const pVal=isNum(ps)?(units==='imperial'?Math.round(ps*100)/100:Math.round(ps*10)/10):null;\r\n          let line='—';\r\n          if(pVal!==null) line=`${pVal} ${precip_label}`;\r\n          if(isNum(pp)) line+=(line==='—'?`${pp}%`:` • ${pp}%`);\r\n          daysHtml+=`<div><p class=\"day-label\">${h(fmtDay(iso))}</p><p>${I18N.max}: ${max}${deg}</p><p>${I18N.min}: ${min}${deg}</p><p>${tLabel}: ${line}</p></div>`;\r\n        }\r\n\r\n        el.innerHTML=`<div class=\"current-weather\" style=\"text-align:center;font:16px system-ui;color:#dbe5f5\">\r\n\t\t   <div class=\"wx-temp\" style=\"font-size:22px;color:#38bdf8;font-weight:500\"><strong>${temp}${deg}</strong></div>\r\n          <div class=\"wx-place\" style=\"font-size:18px;margin-bottom:4px;color:#9fb1cc\"><strong>${h(label)}</strong></div>\r\n        \r\n       \r\n\t\t  \r\n        </div>\r\n\t\t\r\n       <div class=\"weather-foot\" style=\"margin-top:18px;text-align:center;\">\r\n  <a href=\"/weather-settings/\" \r\n     style=\"\r\n       display:inline-block;\r\n       padding:4px 10px;\r\n       font:13px system-ui;\r\n       color:#38bdf8;\r\n       border:.5px solid #256ea8;\r\n       border-radius:4px;\r\n       text-decoration:none;\r\n       transition:all 0.15s ease;\r\n     \"\r\n     onmouseover=\"this.style.background='rgba(56,189,248,0.06)'; this.style.borderColor='rgba(56,189,248,0.4)';\"\r\n     onmouseout=\"this.style.background='transparent';\"\r\n  >\r\n   ${I18N.change}\r\n  </a>\r\n</div>\r\n\t\r\n\t\t\r\n      \r\n\t\t\r\n\t\t\t\t<div style=\"text-align:center; margin-top:22px;\">\r\n  <a href=\"/add-xonaly\" style=\"text-decoration:none;margin-top:22px;color:#9fb1cc;font:14px system-ui;text-align:center\">\r\n \r\nOver 1,3 million pages indexed <br>\r\nAdd to your browser\r\n  </a>\r\n</div>\r\n\t\t\r\n\t\t\r\n        <div class=\"daily-weather\">${daysHtml}</div>`;\r\n      }catch{\r\n        el.innerHTML=`<div class=\"error\">${I18N.error}</div>\r\n          <div style=\"margin-top:10px\"><a href=\"/weather-settings/\" style=\"color:#94a3b8\">${I18N.change}</a></div>`;\r\n      }\r\n    }\r\n    loadWeather();\r\n  })();\r\n  </script>\r\n</section>\r\n\r\n\r\n\r\n\r\n\r\n  </main>\r\n\r\n\r\n\r\n\r\n<footer>\r\n\r\n© 2026 Xonaly. Private search, built in Canada.<br><br>\r\n\r\n<a href=\"https://xonaly.com/privacy-policy\" style=\"font-size:0.75em;margin:0 0.3em;text-decoration:none;\">Privacy</a>\r\n&bull;\r\n<a href=\"https://xonaly.com/terms-of-service\" style=\"font-size:0.75em;margin:0 0.3em;text-decoration:none;\">Terms of Service</a>\r\n&bull;\r\n<a href=\"https://xonaly.com/help\" style=\"font-size:0.75em;margin:0 0.3em;text-decoration:none;\">Help</a>\r\n  \r\n\r\n  <br><br>\r\n  <small style=\"font-size:0.55em;color:#aaa;\">\r\n    <a href=\"/api/\" style=\"color:#aaa;text-decoration:none;\">API Documentation</a>\r\n  </small>\r\n  \r\n</footer>\r\n\r\n<script>\r\n(function(){\r\n  var f = document.querySelector('form[method=\"GET\"]');\r\n  if (!f) return;\r\n\r\n  f.addEventListener('submit', function(){\r\n    try {\r\n      var saved = JSON.parse(localStorage.getItem('xonaly.weather.v1')||'null') || {};\r\n      ['place','units'].forEach(function(k){\r\n        if (saved && saved[k]) {\r\n          var inp = f.querySelector('input[name=\"'+k+'\"]');\r\n          if (!inp) {\r\n            inp = document.createElement('input');\r\n            inp.type = 'hidden';\r\n            inp.name = k;\r\n            f.appendChild(inp);\r\n          }\r\n          inp.value = saved[k];\r\n        }\r\n      });\r\n    }catch(e){}\r\n    var loader = document.getElementById('loader');\r\n    if (loader) loader.style.visibility = 'visible';\r\n  });\r\n})();\r\n</script>\r\n\r\n\r\n<script>\r\n  if (\"serviceWorker\" in navigator) {\r\n    window.addEventListener(\"load\", async () => {\r\n      try {\r\n        await navigator.serviceWorker.register(\"/sw.js\", { scope: \"/\" });\r\n        console.log(\"SW registered\");\r\n      } catch (e) {\r\n        console.log(\"SW failed\", e);\r\n      }\r\n    });\r\n  }\r\n</script>\r\n\r\n\r\n\r\n\r\n</body>\r\n</html>\r\n"
